{
  "name": "@p-vbordei/ws-reconnect",
  "version": "0.2.1",
  "description": "Pure helpers for WebSocket reconnection: exponential backoff with jitter, sequence-gap classifier, RFC 6455 close-code lookup. Zero dependencies.",
  "keywords": [
    "websocket",
    "reconnect",
    "backoff",
    "jitter",
    "sequence",
    "close-code"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/ws-reconnect.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/ws-reconnect/issues"
  },
  "homepage": "https://github.com/p-vbordei/ws-reconnect#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "prettier": "^3.3.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.mjs"
}
